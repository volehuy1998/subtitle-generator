# .scanignore — allowlist for scan_sensitive.py
#
# One regex per line. Lines starting with # are comments.
# If any allowlist pattern matches the finding value OR the full line
# containing the finding, the finding is suppressed.
#
# POLICY: Use sparingly. Every entry requires a comment explaining WHY it is
# safe. All entries are reviewed during security audits.
# See CONTRIBUTING.md §11 for the full sensitive data classification policy.

# ── Category 1: Network / IP allowlist ───────────────────────────────────

# Loopback and wildcard addresses (server binding, not routable)
0\.0\.0\.0
127\.0\.0

# Documentation example IPs — non-routable TEST-NET per RFC 5737
# (192.0.2.0/24, 198.51.100.0/24, 203.0.113.0/24)
192\.0\.2\.
198\.51\.100\.
203\.0\.113\.

# ── Category 2: Credentials allowlist ────────────────────────────────────

# Test fixture passwords — only in test files; not real credentials
password.*=.*test
password.*=.*secret.*test

# Example JWT in documentation (well-known test vector, not a real token)
eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.eyJzdWIiOiIxMjM0NTY3ODkwIg

# ── Category 3: Config allowlist ─────────────────────────────────────────

# .env.example files always use placeholder values — never real credentials
\.env\.example

# Placeholder sentinel values (not real secrets, used in docs/examples)
your-secret-key
your-.*-secret
placeholder
